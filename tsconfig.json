{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": ["vite/client", "vite-plugin-pwa/client"]
  },
  // srcе…ЁдҪ“гӮ’жӨңжҹ»гҒҷгӮӢгҖӮsw.ts гҒҜWebWorker libгҒҢеҝ…иҰҒгҒӘгҒҹгӮҒ tsconfig.sw.json гҒ§еҲҘйҖ”жӨңжҹ»гҒҷгӮӢгҖӮ
  "include": ["src/**/*.ts"],
  "exclude": ["src/sw.ts"]
}
