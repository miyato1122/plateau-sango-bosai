{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": ["vite/client"]
  },
  // 段階導入: .ts化したモジュールを検査対象にする (lib全部 + i18n/config/risk/hazards/weather)。
  // 残る .js (src/app のCesium UI接続層など) の .ts 化は最終段。
  "include": ["src/**/*.ts"]
}
