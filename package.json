{
  "name": "sango-bosai-3d-map",
  "version": "1.0.0",
  "private": true,
  "description": "さんごう防災3Dマップ — 奈良県三郷町のPLATEAU 3D都市モデルを活用した防災Webアプリ",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.sw.json",
    "build:roads": "tsx scripts/build-road-network.mjs"
  },
  "dependencies": {
    "cesium": "^1.143.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
